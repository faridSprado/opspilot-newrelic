# Application
APP_ENV=development
APP_SECRET_KEY=change-me-generate-a-long-random-secret
DATABASE_URL=sqlite:///./opspilot.db
REDIS_URL=

# New Relic
# Region: US or EU
NEW_RELIC_REGION=US
# Optional for local development. The UI can also discover accounts automatically after connecting.
NEW_RELIC_API_KEY=
NEW_RELIC_ACCOUNT_ID=

# LLM provider: none, gemini, or openai
LLM_PROVIDER=none

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Reserved for future tool-provider integrations
MCP_NEW_RELIC_URL=

# Local development
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
